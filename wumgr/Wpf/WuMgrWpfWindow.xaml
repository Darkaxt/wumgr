<Window x:Class="wumgr.Wpf.WuMgrWpfWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Manager for Windows"
        MinWidth="1060"
        MinHeight="680"
        Width="1280"
        Height="760"
        WindowStartupLocation="CenterScreen"
        Background="#f3f5f7">
  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Margin" Value="0,0,8,0" />
    </Style>
    <Style TargetType="ToggleButton">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="#1f2933" />
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="52" />
      <RowDefinition Height="*" />
      <RowDefinition Height="140" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="230" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#ffffff" BorderBrush="#d8dee6" BorderThickness="0,0,0,1">
      <DockPanel Margin="14,0">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
          <TextBlock Text="WuMgr" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
          <TextBlock Text="{Binding VersionText}" Margin="8,2,0,0" Foreground="#607080" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Text="{Binding ElevationText}" DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="#7a4f00" />
      </DockPanel>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Background="#ffffff" BorderBrush="#d8dee6" BorderThickness="0,0,1,0">
      <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom">
          <TextBlock Text="Options" FontWeight="SemiBold" Margin="0,0,0,8" />
          <TextBlock Text="Update source" FontWeight="SemiBold" Margin="0,0,0,6" />
          <ComboBox ItemsSource="{Binding Sources}"
                    SelectedItem="{Binding SelectedSource, Mode=TwoWay}"
                    IsEnabled="{Binding CanUseOnlineSource}"
                    MinHeight="28"
                    Margin="0,0,0,10" />
          <CheckBox Content="Offline mode" IsChecked="{Binding OfflineMode, Mode=TwoWay}" Margin="0,0,0,5" />
          <CheckBox Content="Download offline CAB"
                    IsChecked="{Binding DownloadOfflineCab, Mode=TwoWay}"
                    IsEnabled="{Binding OfflineMode}"
                    Margin="0,0,0,5" />
          <CheckBox Content="Manual download/install" IsChecked="{Binding ManualMode}" Margin="0,0,0,5" />
          <CheckBox Content="Include superseded" IsChecked="{Binding IncludeSuperseded}" Margin="0,0,0,5" />
          <CheckBox Content="Register Microsoft Update"
                    IsChecked="{Binding RegisterMicrosoftUpdate}"
                    IsEnabled="{Binding IsAdministrator}"
                    Margin="0,0,0,16" />
          <CheckBox Content="Always run as Administrator"
                    IsChecked="{Binding SkipUacEnabled}"
                    IsEnabled="{Binding IsAdministrator}" />
        </StackPanel>

        <StackPanel>
          <ToggleButton Content="{Binding PendingLabel}" IsChecked="{Binding IsPendingList, Mode=OneWay}" Click="PendingList_Click" />
          <ToggleButton Content="{Binding InstalledLabel}" IsChecked="{Binding IsInstalledList, Mode=OneWay}" Click="InstalledList_Click" />
          <ToggleButton Content="{Binding HiddenLabel}" IsChecked="{Binding IsHiddenList, Mode=OneWay}" Click="HiddenList_Click" />
          <ToggleButton Content="{Binding HistoryLabel}" IsChecked="{Binding IsHistoryList, Mode=OneWay}" Click="HistoryList_Click" />
          <Separator Margin="0,10" />
          <Button Content="Search" Click="Search_Click" IsEnabled="{Binding CanSearch}" />
          <Button Content="Download" Click="Download_Click" IsEnabled="{Binding CanDownload}" />
          <Button Content="Install" Click="Install_Click" IsEnabled="{Binding CanInstall}" />
          <Button Content="Uninstall" Click="Uninstall_Click" IsEnabled="{Binding CanUninstall}" />
          <Button Content="{Binding HideButtonText}" Click="Hide_Click" IsEnabled="{Binding CanHide}" />
          <Button Content="Get Links" Click="GetLinks_Click" IsEnabled="{Binding CanGetLinks}" />
          <Button Content="Cancel" Click="Cancel_Click" IsEnabled="{Binding CanCancel}" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1" Grid.Column="1" Margin="14">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <DockPanel Grid.Row="0" Margin="0,0,0,10">
        <TextBlock Text="Windows Update" FontSize="20" FontWeight="SemiBold" DockPanel.Dock="Left" />
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
          <Button Content="Refresh" Click="Refresh_Click" />
          <Button Content="Open WinForms UI" Click="OpenWinForms_Click" />
        </StackPanel>
      </DockPanel>

      <DataGrid Grid.Row="1"
                ItemsSource="{Binding Updates}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                IsReadOnly="False"
                SelectionMode="Extended"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                RowHeaderWidth="0">
        <DataGrid.Columns>
          <DataGridCheckBoxColumn Header="" Binding="{Binding Selected, Mode=TwoWay}" Width="38" />
          <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" IsReadOnly="True" />
          <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="190" IsReadOnly="True" />
          <DataGridTextColumn Header="KB Article" Binding="{Binding KB}" Width="100" IsReadOnly="True" />
          <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="105" IsReadOnly="True" />
          <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="95" IsReadOnly="True" />
          <DataGridTextColumn Header="State" Binding="{Binding State}" Width="95" IsReadOnly="True" />
        </DataGrid.Columns>
      </DataGrid>
    </Grid>

    <Border Grid.Row="2" Grid.Column="1" Margin="14,0,14,14" Background="#ffffff" BorderBrush="#d8dee6" BorderThickness="1">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="10,8,10,4">
          <TextBlock Text="Status" FontWeight="SemiBold" />
          <TextBlock Text="{Binding StatusText}" Margin="0,3,0,5" Foreground="#52616f" />
          <ProgressBar Height="8"
                       Minimum="0"
                       Maximum="100"
                       Value="{Binding TotalPercent}"
                       IsIndeterminate="{Binding IsBusyIndeterminate}" />
        </StackPanel>
        <TextBox Text="{Binding StatusLog, Mode=OneWay}"
                 Margin="10,0,10,10"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 BorderThickness="0"
                 Background="#ffffff" />
      </DockPanel>
    </Border>
  </Grid>
</Window>
