<Window x:Class="wumgr.Wpf.WuMgrWpfWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Update Manager for Windows"
        MinWidth="1060"
        MinHeight="680"
        Width="1280"
        Height="760"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#f3f5f7" />
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#ffffff" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#ffffff" />
    <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="#ffffff" />
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#ffffff" />
    <SolidColorBrush x:Key="ControlHoverBrush" Color="#edf4fb" />
    <SolidColorBrush x:Key="ControlPressedBrush" Color="#dcecf8" />
    <SolidColorBrush x:Key="SelectedBackgroundBrush" Color="#d9edf8" />
    <SolidColorBrush x:Key="BorderLineBrush" Color="#d8dee6" />
    <SolidColorBrush x:Key="TextBrush" Color="#1f2933" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#52616f" />
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#758392" />
    <SolidColorBrush x:Key="WarningTextBrush" Color="#7a4f00" />
    <SolidColorBrush x:Key="GridBackgroundBrush" Color="#ffffff" />
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="#f4f6f8" />
    <SolidColorBrush x:Key="GridLineBrush" Color="#dbe3eb" />
    <SolidColorBrush x:Key="ProgressTrackBrush" Color="#d8dee6" />
    <SolidColorBrush x:Key="ProgressFillBrush" Color="#1f9d35" />
    <SolidColorBrush x:Key="ProgressMarqueeBrush" Color="#46a4ff" />

    <Style TargetType="Button">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="3">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Margin="{TemplateBinding Padding}"
                                RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlPressedBrush}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                <Setter Property="Opacity" Value="0.55" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="ToggleButton">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="3">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                <Setter Property="Opacity" Value="0.55" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style TargetType="RadioButton">
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style TargetType="ComboBox">
      <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="6,3" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <ToggleButton x:Name="ComboChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Foreground="{TemplateBinding Foreground}"
                            Focusable="False"
                            ClickMode="Press"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                <ToggleButton.Template>
                  <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                      <Grid>
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                        <Path Data="M 0 0 L 4 4 L 8 0 Z"
                              Fill="{DynamicResource TextBrush}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0" />
                      </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                      </Trigger>
                      <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlPressedBrush}" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </ToggleButton.Template>
                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                  Margin="6,0,22,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center" />
              </ToggleButton>
              <Popup x:Name="Popup"
                     Placement="Bottom"
                     IsOpen="{TemplateBinding IsDropDownOpen}"
                     AllowsTransparency="True"
                     Focusable="False"
                     PopupAnimation="Fade">
                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                  <Border Background="{DynamicResource SurfaceBackgroundBrush}"
                          BorderBrush="{DynamicResource BorderLineBrush}"
                          BorderThickness="1" />
                  <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                  </ScrollViewer>
                </Grid>
              </Popup>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                <Setter Property="Opacity" Value="0.55" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="ComboBoxItem">
      <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBoxItem">
            <Border x:Name="Chrome" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
    </Style>
    <Style TargetType="TabControl">
      <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style TargetType="TabItem">
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="1,1,1,0"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter ContentSource="Header"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="DataGrid">
      <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderLineBrush}" />
      <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource GridLineBrush}" />
      <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource GridLineBrush}" />
      <Setter Property="RowBackground" Value="{DynamicResource GridBackgroundBrush}" />
      <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceBackgroundBrush}" />
    </Style>
    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource GridHeaderBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource GridLineBrush}" />
      <Setter Property="Padding" Value="6,3" />
    </Style>
    <Style TargetType="DataGridRow">
      <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style TargetType="DataGridCell">
      <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource GridLineBrush}" />
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
          <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="ActionIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="2" />
      <Setter Property="Margin" Value="0,0,4,0" />
    </Style>
    <Style x:Key="WindowCaptionButtonStyle" TargetType="Button">
      <Setter Property="Width" Value="42" />
      <Setter Property="Height" Value="32" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="10" />
    </Style>
  </Window.Resources>

  <Border BorderBrush="{DynamicResource BorderLineBrush}" BorderThickness="1">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="52" />
      <RowDefinition Height="*" />
      <RowDefinition Height="140" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="230" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            Background="{DynamicResource HeaderBackgroundBrush}"
            BorderBrush="{DynamicResource BorderLineBrush}"
            BorderThickness="0,0,0,1"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
      <DockPanel Margin="14,0">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
          <TextBlock Text="{Binding ElevationText}"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource WarningTextBrush}"
                     Margin="0,0,12,0" />
          <Button x:Name="MinimizeWindowButton"
                  Style="{StaticResource WindowCaptionButtonStyle}"
                  Click="MinimizeWindow_Click" />
          <Button x:Name="MaximizeWindowButton"
                  Style="{StaticResource WindowCaptionButtonStyle}"
                  Click="MaximizeRestoreWindow_Click" />
          <Button x:Name="CloseWindowButton"
                  Style="{StaticResource WindowCaptionButtonStyle}"
                  Click="CloseWindow_Click" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
          <TextBlock Text="WuMgr" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
          <TextBlock Text="{Binding VersionText}" Margin="8,2,0,0" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderLineBrush}" BorderThickness="0,0,1,0">
      <DockPanel Margin="12">
        <TabControl DockPanel.Dock="Bottom" MinHeight="314" Margin="0,10,0,0">
          <TabItem Header="{Binding Text.OptionsTab}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="6">
                <CheckBox Content="{Binding Text.RunInBackground}"
                          IsChecked="{Binding RunInBackground, Mode=TwoWay}"
                          IsEnabled="{Binding CanChangeRunInBackground}"
                          Margin="0,0,0,5" />
                <ComboBox ItemsSource="{Binding AutoUpdateOptions}"
                          SelectedIndex="{Binding SelectedAutoUpdateIndex, Mode=TwoWay}"
                          IsEnabled="{Binding RunInBackground}"
                          MinHeight="28"
                          Margin="0,0,0,10" />
                <TextBlock Text="{Binding Text.ThemeLabel}" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ComboBox ItemsSource="{Binding ThemeOptions}"
                          SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}"
                          MinHeight="28"
                          Margin="0,0,0,10" />
                <TextBlock Text="{Binding Text.UpdateSource}" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ComboBox ItemsSource="{Binding Sources}"
                          SelectedItem="{Binding SelectedSource, Mode=TwoWay}"
                          IsEnabled="{Binding CanUseOnlineSource}"
                          MinHeight="28"
                          Margin="0,0,0,10" />
                <CheckBox Content="{Binding Text.OfflineMode}" IsChecked="{Binding OfflineMode, Mode=TwoWay}" Margin="0,0,0,5" />
                <CheckBox Content="{Binding Text.DownloadOfflineCab}"
                          IsChecked="{Binding DownloadOfflineCab, Mode=TwoWay}"
                          IsEnabled="{Binding OfflineMode}"
                          Margin="0,0,0,5" />
                <CheckBox Content="{Binding Text.ManualDownloadInstall}" IsChecked="{Binding ManualMode}" Margin="0,0,0,5" />
                <CheckBox Content="{Binding Text.IncludeSuperseded}" IsChecked="{Binding IncludeSuperseded}" Margin="0,0,0,5" />
                <CheckBox Content="{Binding Text.RegisterMicrosoftUpdate}"
                          IsChecked="{Binding RegisterMicrosoftUpdate}"
                          IsEnabled="{Binding IsAdministrator}"
                          Margin="0,0,0,16" />
                <CheckBox Content="{Binding Text.AlwaysRunAsAdministrator}"
                          IsChecked="{Binding SkipUacEnabled}"
                          IsEnabled="{Binding IsAdministrator}" />
              </StackPanel>
            </ScrollViewer>
          </TabItem>
          <TabItem Header="{Binding Text.AutoUpdateTab}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="6">
                <CheckBox Content="{Binding Text.BlockMicrosoftServers}"
                          IsChecked="{Binding BlockMicrosoftServers, Mode=TwoWay}"
                          IsThreeState="True"
                          IsEnabled="{Binding CanChangeBlockMicrosoft}"
                          Margin="0,0,0,7" />
                <RadioButton Content="{Binding Text.DisableAutomaticUpdate}"
                             GroupName="PolicyAutoUpdate"
                             IsChecked="{Binding IsPolicyDisabled, Mode=TwoWay}"
                             IsEnabled="{Binding IsAdministrator}"
                             Margin="0,0,0,5" />
                <CheckBox Content="{Binding Text.DisableUpdateFacilitators}"
                          IsChecked="{Binding DisableUpdateFacilitators, Mode=TwoWay}"
                          IsEnabled="{Binding CanChangeDisableFacilitators}"
                          Margin="16,0,0,7" />
                <RadioButton Content="{Binding Text.NotificationOnly}"
                             GroupName="PolicyAutoUpdate"
                             IsChecked="{Binding IsPolicyNotification, Mode=TwoWay}"
                             IsEnabled="{Binding CanSelectNotification}"
                             Margin="0,0,0,5" />
                <RadioButton Content="{Binding Text.DownloadOnly}"
                             GroupName="PolicyAutoUpdate"
                             IsChecked="{Binding IsPolicyDownload, Mode=TwoWay}"
                             IsEnabled="{Binding CanSelectDownload}"
                             Margin="0,0,0,5" />
                <RadioButton Content="{Binding Text.ScheduledInstallation}"
                             GroupName="PolicyAutoUpdate"
                             IsChecked="{Binding IsPolicyScheduled, Mode=TwoWay}"
                             IsEnabled="{Binding CanSelectScheduled}"
                             Margin="0,0,0,5" />
                <StackPanel Orientation="Horizontal" Margin="16,0,0,7">
                  <ComboBox ItemsSource="{Binding ScheduleDays}"
                            SelectedIndex="{Binding SelectedScheduleDay, Mode=TwoWay}"
                            IsEnabled="{Binding CanChangeSchedule}"
                            Width="96"
                            MinHeight="26"
                            Margin="0,0,6,0" />
                  <ComboBox ItemsSource="{Binding ScheduleTimes}"
                            SelectedIndex="{Binding SelectedScheduleTime, Mode=TwoWay}"
                            IsEnabled="{Binding CanChangeSchedule}"
                            Width="70"
                            MinHeight="26" />
                </StackPanel>
                <RadioButton Content="{Binding Text.AutomaticUpdateDefault}"
                             GroupName="PolicyAutoUpdate"
                             IsChecked="{Binding IsPolicyDefault, Mode=TwoWay}"
                             IsEnabled="{Binding IsAdministrator}"
                             Margin="0,0,0,8" />
                <Separator Margin="0,0,0,8" />
                <CheckBox Content="{Binding Text.HideWindowsUpdateSettings}"
                          IsChecked="{Binding HideWindowsUpdatePage, Mode=TwoWay}"
                          IsEnabled="{Binding CanChangeHideWindowsUpdatePage}"
                          Margin="0,0,0,5" />
                <CheckBox Content="{Binding Text.DisableStoreAutoUpdate}"
                          IsChecked="{Binding DisableStoreAutoUpdate, Mode=TwoWay}"
                          IsEnabled="{Binding CanChangeStoreAutoUpdate}"
                          Margin="0,0,0,5" />
                <CheckBox Content="{Binding Text.IncludeDrivers}"
                          IsChecked="{Binding IncludeDriversInUpdates, Mode=TwoWay}"
                          IsThreeState="True"
                          IsEnabled="{Binding CanChangeDrivers}" />
              </StackPanel>
            </ScrollViewer>
          </TabItem>
        </TabControl>

        <StackPanel>
          <ToggleButton Content="{Binding PendingLabel}" IsChecked="{Binding IsPendingList, Mode=OneWay}" Click="PendingList_Click" />
          <ToggleButton Content="{Binding InstalledLabel}" IsChecked="{Binding IsInstalledList, Mode=OneWay}" Click="InstalledList_Click" />
          <ToggleButton Content="{Binding HiddenLabel}" IsChecked="{Binding IsHiddenList, Mode=OneWay}" Click="HiddenList_Click" />
          <ToggleButton Content="{Binding HistoryLabel}" IsChecked="{Binding IsHistoryList, Mode=OneWay}" Click="HistoryList_Click" />
          <Separator Margin="0,10" />
          <StackPanel Orientation="Horizontal">
            <Button x:Name="SearchActionButton" Style="{StaticResource ActionIconButtonStyle}" Click="Search_Click" IsEnabled="{Binding CanSearch}" />
            <Button x:Name="DownloadActionButton" Style="{StaticResource ActionIconButtonStyle}" Click="Download_Click" IsEnabled="{Binding CanDownload}" />
            <Button x:Name="InstallActionButton" Style="{StaticResource ActionIconButtonStyle}" Click="Install_Click" IsEnabled="{Binding CanInstall}" />
            <Button x:Name="UninstallActionButton" Style="{StaticResource ActionIconButtonStyle}" Click="Uninstall_Click" IsEnabled="{Binding CanUninstall}" />
            <Button x:Name="HideActionButton" Style="{StaticResource ActionIconButtonStyle}" Click="Hide_Click" IsEnabled="{Binding CanHide}" />
            <Button x:Name="GetLinksActionButton" Style="{StaticResource ActionIconButtonStyle}" Click="GetLinks_Click" IsEnabled="{Binding CanGetLinks}" />
            <Button x:Name="CancelActionButton" Style="{StaticResource ActionIconButtonStyle}" Click="Cancel_Click" IsEnabled="{Binding CanCancel}" />
          </StackPanel>
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1" Grid.Column="1" Margin="14">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="False">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
          <TextBlock Text="{Binding Text.SearchFilter}"
                     VerticalAlignment="Center"
                     Margin="0,0,6,0"
                     Foreground="{DynamicResource MutedTextBrush}" />
          <TextBox Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged}"
                   Width="260"
                   MinHeight="30"
                   Padding="7,5"
                   Margin="0,0,4,0" />
          <Button Style="{StaticResource ActionIconButtonStyle}"
                  Content="&#xE711;"
                  FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                  ToolTip="{Binding Text.ClearFilter}"
                  Click="ClearFilter_Click"
                  IsEnabled="{Binding HasSearchFilter}" />
          <Button x:Name="RefreshActionButton"
                  Style="{StaticResource ActionIconButtonStyle}"
                  Click="Refresh_Click" />
        </StackPanel>
        <TextBlock Text="{Binding Text.WindowsUpdateHeading}" FontSize="20" FontWeight="SemiBold" DockPanel.Dock="Left" />
      </DockPanel>

      <DataGrid Grid.Row="1"
                ItemsSource="{Binding Updates}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                IsReadOnly="False"
                SelectionMode="Extended"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                RowHeaderWidth="0">
        <DataGrid.Columns>
          <DataGridCheckBoxColumn x:Name="SelectionColumn" Binding="{Binding Selected, Mode=TwoWay}" Width="38">
            <DataGridCheckBoxColumn.Header>
              <CheckBox x:Name="SelectAllRowsCheckBox"
                        IsThreeState="True"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="SelectAllRows_Click" />
            </DataGridCheckBoxColumn.Header>
          </DataGridCheckBoxColumn>
          <DataGridTextColumn x:Name="TitleColumn" Binding="{Binding Title}" Width="*" IsReadOnly="True" />
          <DataGridTextColumn x:Name="CategoryColumn" Binding="{Binding Category}" Width="190" IsReadOnly="True" />
          <DataGridTextColumn x:Name="KbColumn" Binding="{Binding KB}" Width="100" IsReadOnly="True" />
          <DataGridTextColumn x:Name="DateColumn" Binding="{Binding Date}" Width="105" IsReadOnly="True" />
          <DataGridTextColumn x:Name="SizeColumn" Binding="{Binding Size}" Width="95" IsReadOnly="True" />
          <DataGridTextColumn x:Name="StateColumn" Binding="{Binding State}" Width="95" IsReadOnly="True" />
        </DataGrid.Columns>
      </DataGrid>
    </Grid>

    <Border Grid.Row="2" Grid.Column="1" Margin="14,0,14,14" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderLineBrush}" BorderThickness="1">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="10,8,10,4">
          <TextBlock Text="{Binding Text.StatusHeader}" FontWeight="SemiBold" />
          <TextBlock Text="{Binding StatusText}" Margin="0,3,0,5" Foreground="{DynamicResource MutedTextBrush}" />
          <Border Height="16" BorderBrush="{DynamicResource BorderLineBrush}" BorderThickness="1" Background="{DynamicResource ProgressTrackBrush}" CornerRadius="2" ClipToBounds="True">
            <Grid x:Name="ProgressTrack" SizeChanged="ProgressTrack_SizeChanged">
              <Border x:Name="ProgressFill" Background="{DynamicResource ProgressFillBrush}" HorizontalAlignment="Left" Width="0" CornerRadius="1" />
              <Border x:Name="ProgressMarquee" Background="{DynamicResource ProgressMarqueeBrush}" HorizontalAlignment="Left" Width="0" CornerRadius="1" Visibility="Collapsed">
                <Border.RenderTransform>
                  <TranslateTransform x:Name="ProgressMarqueeTransform" />
                </Border.RenderTransform>
              </Border>
              <TextBlock x:Name="ProgressLabel"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontSize="10"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextBrush}" />
            </Grid>
          </Border>
        </StackPanel>
        <TextBox Text="{Binding StatusLog, Mode=OneWay}"
                 Margin="10,0,10,10"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 BorderThickness="0"
